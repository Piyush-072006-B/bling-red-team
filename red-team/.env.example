RED_TEAM_API_KEY=changeme
PII_HASH_SALT=red-team-salt-changeme

# REQUIRED: Must point to Blue Team shadow scorer service, NOT Red Team itself.
# Leave empty to disable shadow scoring (scores will return null).
BLUE_TEAM_SHADOW_API_KEY=
BLUE_TEAM_SHADOW_URL=

# Blue Team main API base URL (reference only)
BLUE_TEAM_INGEST_URL=http://localhost:8000/api/v1

# TGEP outbound webhook URL (leave empty if not yet configured)
TGEP_WEBHOOK_URL=

# Database (deferred post-hackathon — currently in-memory only)
POSTGRES_URL=postgresql://redteam:redteam@localhost:5433/redteam
REDIS_URL=redis://localhost:6380

# Rate limiting
INGEST_RATE_LIMIT=500/minute

# Queue sizing (per priority tier; 503 returned when full)
INGEST_QUEUE_MAX_SIZE=1000
